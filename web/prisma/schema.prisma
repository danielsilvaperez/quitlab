generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  substanceProfiles SubstanceProfile[]
  quitPlans         QuitPlan[]
  checkIns          DailyCheckIn[]
  triggerEvents     TriggerEvent[]
  copingPlans       CopingPlan[]
  posts             Post[]
  comments          Comment[]
  reactions         Reaction[]
  reportsSubmitted  Report[] @relation("ReportReporter")
  reportsResolved   Report[] @relation("ReportResolver")
  moderationActions ModerationAction[]
  blockedBy         Block[] @relation("BlockedBy")
  blocks            Block[] @relation("Blocker")
}

model SubstanceProfile {
  id          String   @id @default(cuid())
  userId      String
  substance   String   // nicotine, marijuana, vaping, alcohol
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, substance])
}

model QuitPlan {
  id              String    @id @default(cuid())
  userId          String
  substance       String
  planType        String    // cold_turkey, gradual_reduction
  quitDate        DateTime?
  dailyTarget     Float?    // for gradual reduction
  dailyCostBefore Float?    // for savings calculation
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyCheckIn {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  cravings  Int      // 0-10 scale
  used      Boolean
  amount    Float?   // amount used if any
  mood      Int      // 1-5 scale
  sleep     Int      // hours slept
  triggers  String?  // JSON array of triggers
  notes     String?
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
}

model TriggerEvent {
  id          String   @id @default(cuid())
  userId      String
  trigger     String
  intensity   Int      // 0-10
  timestamp   DateTime @default(now())
  handled     Boolean  @default(false)
  copingUsed  String?  // which coping strategy was used
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CopingPlan {
  id        String   @id @default(cuid())
  userId    String
  trigger   String
  action    String   // "If [trigger], then I will [action]"
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CommunityRoom {
  id        String   @id @default(cuid())
  name        String   @unique
  description String
  substance   String   // nicotine, marijuana, etc.
  createdAt   DateTime @default(now())
  
  posts Post[]
}

model Post {
  id        String   @id @default(cuid())
  roomId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  room     CommunityRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author   User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  reactions Reaction[]
  reports   Report[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions Reaction[]
  reports   Report[]
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  commentId String?
  type      String   // like, support, celebrate
  createdAt DateTime @default(now())
  
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  @@unique([userId, postId, commentId])
}

model Report {
  id           String   @id @default(cuid())
  reporterId   String
  postId       String?
  commentId    String?
  reason       String
  status       String   @default("pending") // pending, resolved, dismissed
  createdAt    DateTime @default(now())
  resolvedAt   DateTime?
  resolvedById String?
  
  reporter   User               @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  post       Post?              @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment    Comment?           @relation(fields: [commentId], references: [id], onDelete: Cascade)
  resolvedBy User?              @relation("ReportResolver", fields: [resolvedById], references: [id])
  action     ModerationAction[]
}

model ModerationAction {
  id          String   @id @default(cuid())
  reportId    String
  moderatorId String
  action      String   // warning, content_removed, user_banned
  details     String?
  createdAt   DateTime @default(now())
  
  report    Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  moderator User   @relation(fields: [moderatorId], references: [id], onDelete: Cascade)
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  
  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)
  
  @@unique([blockerId, blockedId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
